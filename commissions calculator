<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>A 和 B 年度提成占比计算器</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&display=swap');
        
        body {
            font-family: 'Noto Sans SC', system-ui, sans-serif;
        }
        
        .card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .result-box {
            animation: fadeIn 0.5s ease forwards;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .input-focus:focus {
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.3);
        }
    </style>
</head>
<body class="bg-gradient-to-br from-blue-50 to-indigo-50 min-h-screen pb-12">
    <div class="max-w-5xl mx-auto px-4 py-8">
        <!-- 标题栏 -->
        <div class="text-center mb-10">
            <div class="inline-flex items-center gap-3 bg-white shadow-md rounded-3xl px-8 py-4">
                <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-2xl flex items-center justify-center text-white text-2xl font-bold">💰</div>
                <h1 class="text-3xl font-bold text-gray-800 tracking-tight">A 和 B 年度提成占比计算器</h1>
            </div>
            <p class="mt-3 text-gray-500 text-lg">年度总提成固定为 6 万元 • 前三季度 50%/50% • 第四季度 55%/45%</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            
            <!-- 正向计算：根据季度提成算年度占比 -->
            <div class="card bg-white rounded-3xl shadow-xl p-8 border border-blue-100">
                <div class="flex items-center gap-2 mb-6">
                    <div class="w-8 h-8 bg-blue-500 text-white rounded-2xl flex items-center justify-center font-bold text-lg">1</div>
                    <h2 class="text-2xl font-semibold text-gray-800">正向计算</h2>
                    <span class="text-blue-600 text-sm font-medium px-3 py-1 bg-blue-100 rounded-3xl">已知季度金额 → 计算年度占比</span>
                </div>
                
                <div class="space-y-8">
                    <!-- 总提成 -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2 flex items-center gap-2">
                            <span>📅 年度总提成</span>
                            <span class="text-xs bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-xl">固定 6 万元</span>
                        </label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-xl">¥</span>
                            <input 
                                id="totalAmount"
                                type="number"
                                value="60000"
                                step="100"
                                class="input-focus w-full pl-9 pr-4 py-4 text-3xl font-semibold border border-gray-200 rounded-3xl focus:border-blue-500 outline-none text-gray-800"
                                oninput="calculateForward()">
                        </div>
                    </div>

                    <!-- 前三季度 -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">📊 前三季度合计提成（Q1+Q2+Q3）</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-xl">¥</span>
                            <input 
                                id="firstThree"
                                type="number"
                                value="42000"
                                step="100"
                                class="input-focus w-full pl-9 pr-4 py-4 text-3xl font-semibold border border-gray-200 rounded-3xl focus:border-blue-500 outline-none text-gray-800"
                                oninput="calculateForward()">
                            <div id="firstThreePercent" class="absolute right-4 top-1/2 -translate-y-1/2 text-xs font-medium text-gray-500 bg-gray-100 px-3 py-1 rounded-2xl"></div>
                        </div>
                    </div>

                    <!-- 第四季度自动显示 -->
                    <div class="bg-gray-50 rounded-3xl p-5 flex justify-between items-center">
                        <div class="text-sm font-medium text-gray-700">📅 第四季度提成（Q4）</div>
                        <div id="q4AmountDisplay" class="text-3xl font-semibold text-indigo-600">¥18,000</div>
                    </div>

                    <!-- 计算结果 -->
                    <div id="forwardResult" class="result-box space-y-4">
                        <div class="grid grid-cols-2 gap-4">
                            <!-- A 的结果 -->
                            <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-3xl p-6 border border-blue-200">
                                <div class="flex justify-between items-start">
                                    <div>
                                        <div class="flex items-center gap-2">
                                            <div class="w-6 h-6 bg-blue-500 rounded-2xl flex items-center justify-center text-white text-lg">A</div>
                                            <p class="font-semibold text-blue-900">A 年度提成</p>
                                        </div>
                                        <div id="aTotalForward" class="text-4xl font-bold text-blue-700 mt-2">¥30,900</div>
                                        <div id="aPercentForward" class="text-2xl font-semibold text-blue-600">51.50%</div>
                                    </div>
                                    <div class="text-right text-xs text-blue-400 font-medium">年度占比</div>
                                </div>
                                
                                <div class="mt-6 pt-6 border-t border-blue-200 text-xs space-y-3">
                                    <div class="flex justify-between">
                                        <span class="text-blue-700">前三季度提成</span>
                                        <span id="aFirst3Forward" class="font-medium">¥21,000</span>
                                    </div>
                                    <div class="flex justify-between">
                                        <span class="text-blue-700">第四季度提成</span>
                                        <span id="aQ4Forward" class="font-medium">¥9,900</span>
                                    </div>
                                </div>
                            </div>

                            <!-- B 的结果 -->
                            <div class="bg-gradient-to-br from-emerald-50 to-emerald-100 rounded-3xl p-6 border border-emerald-200">
                                <div class="flex justify-between items-start">
                                    <div>
                                        <div class="flex items-center gap-2">
                                            <div class="w-6 h-6 bg-emerald-500 rounded-2xl flex items-center justify-center text-white text-lg">B</div>
                                            <p class="font-semibold text-emerald-900">B 年度提成</p>
                                        </div>
                                        <div id="bTotalForward" class="text-4xl font-bold text-emerald-700 mt-2">¥29,100</div>
                                        <div id="bPercentForward" class="text-2xl font-semibold text-emerald-600">48.50%</div>
                                    </div>
                                    <div class="text-right text-xs text-emerald-400 font-medium">年度占比</div>
                                </div>
                                
                                <div class="mt-6 pt-6 border-t border-emerald-200 text-xs space-y-3">
                                    <div class="flex justify-between">
                                        <span class="text-emerald-700">前三季度提成</span>
                                        <span id="bFirst3Forward" class="font-medium">¥21,000</span>
                                    </div>
                                    <div class="flex justify-between">
                                        <span class="text-emerald-700">第四季度提成</span>
                                        <span id="bQ4Forward" class="font-medium">¥8,100</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 反向计算：根据年度占比反推季度提成 -->
            <div class="card bg-white rounded-3xl shadow-xl p-8 border border-indigo-100">
                <div class="flex items-center gap-2 mb-6">
                    <div class="w-8 h-8 bg-indigo-500 text-white rounded-2xl flex items-center justify-center font-bold text-lg">2</div>
                    <h2 class="text-2xl font-semibold text-gray-800">反向计算</h2>
                    <span class="text-indigo-600 text-sm font-medium px-3 py-1 bg-indigo-100 rounded-3xl">已知年度占比 → 反推季度提成</span>
                </div>
                
                <div class="space-y-8">
                    <!-- 总提成 -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">📅 年度总提成</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-xl">¥</span>
                            <input 
                                id="totalAmountReverse"
                                type="number"
                                value="60000"
                                step="100"
                                class="input-focus w-full pl-9 pr-4 py-4 text-3xl font-semibold border border-gray-200 rounded-3xl focus:border-indigo-500 outline-none text-gray-800"
                                oninput="calculateReverse()">
                        </div>
                    </div>

                    <!-- A 的年度占比 -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2 flex items-center gap-2">
                            <span>A 的年度提成占比</span>
                            <span class="px-3 py-1 text-xs font-medium bg-amber-100 text-amber-700 rounded-3xl">必须在 50%～55% 之间</span>
                        </label>
                        <div class="flex items-center gap-3">
                            <input 
                                id="aAnnualPercent"
                                type="number"
                                value="52"
                                step="0.01"
                                min="50"
                                max="55"
                                class="input-focus w-28 text-center text-5xl font-bold border border-gray-200 rounded-3xl focus:border-indigo-500 outline-none text-gray-800"
                                oninput="calculateReverse()">
                            <div class="text-5xl font-light text-gray-400">%</div>
                            <div class="flex-1 h-2 bg-gradient-to-r from-blue-400 to-indigo-500 rounded-3xl relative">
                                <div id="percentSlider" class="absolute top-1/2 -translate-y-1/2 w-4 h-4 bg-white shadow-lg border-2 border-indigo-500 rounded-2xl transition-all"></div>
                            </div>
                        </div>
                        <div class="flex justify-between text-xs text-gray-400 mt-1">
                            <div>50%（全在前三季度）</div>
                            <div>55%（全在第四季度）</div>
                        </div>
                    </div>

                    <!-- 反向结果 -->
                    <div id="reverseResult" class="result-box">
                        <div class="bg-gradient-to-br from-indigo-50 to-violet-50 rounded-3xl p-6 mb-6">
                            <div class="text-xs font-medium text-indigo-700 mb-4 flex items-center justify-between">
                                <span>✅ 计算成功（前三季度 + 第四季度）</span>
                                <span id="reverseStatus" class="px-4 py-1 bg-white text-emerald-600 rounded-3xl text-xs font-semibold">可行</span>
                            </div>
                            
                            <div class="grid grid-cols-2 gap-6">
                                <!-- 前三季度 -->
                                <div>
                                    <p class="text-xs uppercase tracking-widest text-indigo-500 mb-2">📊 前三季度合计</p>
                                    <div id="firstThreeReverse" class="text-4xl font-bold text-indigo-700">¥36,000</div>
                                    <div class="text-xs text-gray-500 mt-1">A / B 各占 50%</div>
                                    <div class="mt-4 flex justify-between text-sm">
                                        <div><span class="text-blue-600">A 前三：</span><span id="aFirst3Reverse" class="font-semibold">¥18,000</span></div>
                                        <div><span class="text-emerald-600">B 前三：</span><span id="bFirst3Reverse" class="font-semibold">¥18,000</span></div>
                                    </div>
                                </div>
                                
                                <!-- 第四季度 -->
                                <div>
                                    <p class="text-xs uppercase tracking-widest text-indigo-500 mb-2">📅 第四季度</p>
                                    <div id="q4Reverse" class="text-4xl font-bold text-violet-700">¥24,000</div>
                                    <div class="text-xs text-gray-500 mt-1">A 占 55% • B 占 45%</div>
                                    <div class="mt-4 flex justify-between text-sm">
                                        <div><span class="text-blue-600">A 第四：</span><span id="aQ4Reverse" class="font-semibold">¥13,200</span></div>
                                        <div><span class="text-emerald-600">B 第四：</span><span id="bQ4Reverse" class="font-semibold">¥10,800</span></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- 验证 -->
                        <div class="flex items-center justify-between text-sm bg-white border border-indigo-100 rounded-3xl px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="text-indigo-600">A 年度应得</div>
                                <div id="aTotalReverseVerify" class="font-bold text-2xl text-indigo-700">¥31,200</div>
                            </div>
                            <div class="h-8 w-px bg-indigo-200"></div>
                            <div id="aPercentReverseVerify" class="font-semibold text-3xl text-indigo-600">52.00%</div>
                            <div class="text-xs text-gray-400 text-right">已匹配输入占比</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 说明栏 -->
        <div class="mt-12 bg-white rounded-3xl p-8 text-sm text-gray-600 shadow-inner border border-gray-100">
            <div class="flex items-start gap-8">
                <div class="flex-1">
                    <h3 class="font-semibold text-gray-800 mb-3 flex items-center gap-2">
                        📌 使用说明
                    </h3>
                    <ul class="space-y-2 text-xs leading-relaxed">
                        <li class="flex gap-2"><span class="font-mono text-blue-500">•</span> 正向计算：输入「年度总提成」和「前三季度合计提成」，系统自动计算第四季度及 A、B 的年度占比和明细。</li>
                        <li class="flex gap-2"><span class="font-mono text-blue-500">•</span> 反向计算：输入 A 的目标年度占比（50%~55%），系统自动反推出前三季度和第四季度的提成金额。</li>
                        <li class="flex gap-2"><span class="font-mono text-blue-500">•</span> 所有数据实时计算，无需点击按钮。</li>
                        <li class="flex gap-2"><span class="font-mono text-blue-500">•</span> 前三季度指 Q1+Q2+Q3 合计（分配比例固定 50%/50%）。</li>
                    </ul>
                </div>
                <div class="flex-1 border-l border-gray-200 pl-8">
                    <h3 class="font-semibold text-gray-800 mb-3">💡 计算公式</h3>
                    <div class="text-xs font-mono bg-gray-50 p-4 rounded-2xl space-y-3">
                        <div>A 年度提成 = 0.5 × 前三季度 + 0.55 × 第四季度</div>
                        <div>B 年度提成 = 0.5 × 前三季度 + 0.45 × 第四季度</div>
                        <div class="pt-2 border-t text-amber-600">反推公式：前三季度 = 总提成 × (0.55 − A年度占比) ÷ 0.05</div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="text-center mt-10 text-xs text-gray-400">
            网页由 Grok 生成 • 纯前端本地运行 • 可直接保存为 .html 文件使用
        </div>
    </div>

    <script>
        // Tailwind 脚本初始化
        function initTailwind() {
            return {
                config(userConfig = {}) {
                    return {
                        configUser: userConfig,
                        defaultTheme: {
                            extend: {},
                        },
                    }
                },
                theme(userConfig = {}) {
                    return {
                        ...this.defaultTheme,
                        ...this.config(userConfig).configUser,
                    }
                },
            }
        }
        
        // 全局变量
        let totalForward = 60000;
        let totalReverse = 60000;
        
        // 正向计算
        function calculateForward() {
            const totalInput = document.getElementById('totalAmount');
            const firstThreeInput = document.getElementById('firstThree');
            
            totalForward = parseFloat(totalInput.value) || 60000;
            let firstThree = parseFloat(firstThreeInput.value) || 0;
            
            // 限制范围
            if (firstThree < 0) firstThree = 0;
            if (firstThree > totalForward) firstThree = totalForward;
            
            const q4 = totalForward - firstThree;
            
            // 计算 A、B
            const aFirst3 = 0.5 * firstThree;
            const aQ4 = 0.55 * q4;
            const aTotal = aFirst3 + aQ4;
            
            const bFirst3 = 0.5 * firstThree;
            const bQ4 = 0.45 * q4;
            const bTotal = bFirst3 + bQ4;
            
            const aPercent = (aTotal / totalForward * 100).toFixed(2);
            const bPercent = (bTotal / totalForward * 100).toFixed(2);
            
            // 更新显示
            document.getElementById('q4AmountDisplay').textContent = `¥${q4.toLocaleString('zh-CN')}`;
            
            // 前三季度百分比显示
            const firstThreePercentEl = document.getElementById('firstThreePercent');
            const firstThreePct = totalForward > 0 ? ((firstThree / totalForward) * 100).toFixed(0) : 0;
            firstThreePercentEl.textContent = `${firstThreePct}%`;
            
            // A
            document.getElementById('aTotalForward').textContent = `¥${Math.round(aTotal).toLocaleString('zh-CN')}`;
            document.getElementById('aPercentForward').textContent = `${aPercent}%`;
            document.getElementById('aFirst3Forward').textContent = `¥${Math.round(aFirst3).toLocaleString('zh-CN')}`;
            document.getElementById('aQ4Forward').textContent = `¥${Math.round(aQ4).toLocaleString('zh-CN')}`;
            
            // B
            document.getElementById('bTotalForward').textContent = `¥${Math.round(bTotal).toLocaleString('zh-CN')}`;
            document.getElementById('bPercentForward').textContent = `${bPercent}%`;
            document.getElementById('bFirst3Forward').textContent = `¥${Math.round(bFirst3).toLocaleString('zh-CN')}`;
            document.getElementById('bQ4Forward').textContent = `¥${Math.round(bQ4).toLocaleString('zh-CN')}`;
            
            // 同步反向的总提成
            if (totalForward !== totalReverse) {
                totalReverse = totalForward;
                document.getElementById('totalAmountReverse').value = totalForward;
                calculateReverse();
            }
        }
        
        // 反向计算
        function calculateReverse() {
            const totalInput = document.getElementById('totalAmountReverse');
            const aPercentInput = document.getElementById('aAnnualPercent');
            
            totalReverse = parseFloat(totalInput.value) || 60000;
            let aAnnualPct = parseFloat(aPercentInput.value) || 52;
            
            // 限制 50~55
            if (aAnnualPct < 50) aAnnualPct = 50;
            if (aAnnualPct > 55) aAnnualPct = 55;
            aPercentInput.value = aAnnualPct.toFixed(2);
            
            const r = aAnnualPct / 100; // A 的年度占比（小数）
            
            // 反推前三季度 S
            // S = total * (0.55 - r) / 0.05
            let firstThree = totalReverse * (0.55 - r) / 0.05;
            
            // 范围检查
            const isValid = firstThree >= 0 && firstThree <= totalReverse;
            
            if (!isValid) {
                document.getElementById('reverseStatus').innerHTML = `
                    <span class="text-red-500 font-semibold">⚠️ 不可行</span>
                `;
                document.getElementById('reverseResult').style.opacity = '0.4';
                return;
            } else {
                document.getElementById('reverseStatus').innerHTML = `✅ 可行`;
                document.getElementById('reverseResult').style.opacity = '1';
            }
            
            const q4 = totalReverse - firstThree;
            
            // A 和 B 的明细
            const aFirst3 = 0.5 * firstThree;
            const aQ4 = 0.55 * q4;
            const bFirst3 = 0.5 * firstThree;
            const bQ4 = 0.45 * q4;
            
            const aTotal = aFirst3 + aQ4;
            const verifyPercent = (aTotal / totalReverse * 100).toFixed(2);
            
            // 更新 UI
            document.getElementById('firstThreeReverse').textContent = `¥${Math.round(firstThree).toLocaleString('zh-CN')}`;
            document.getElementById('q4Reverse').textContent = `¥${Math.round(q4).toLocaleString('zh-CN')}`;
            
            document.getElementById('aFirst3Reverse').textContent = `¥${Math.round(aFirst3).toLocaleString('zh-CN')}`;
            document.getElementById('bFirst3Reverse').textContent = `¥${Math.round(bFirst3).toLocaleString('zh-CN')}`;
            document.getElementById('aQ4Reverse').textContent = `¥${Math.round(aQ4).toLocaleString('zh-CN')}`;
            document.getElementById('bQ4Reverse').textContent = `¥${Math.round(bQ4).toLocaleString('zh-CN')}`;
            
            document.getElementById('aTotalReverseVerify').textContent = `¥${Math.round(aTotal).toLocaleString('zh-CN')}`;
            document.getElementById('aPercentReverseVerify').textContent = `${verifyPercent}%`;
            
            // 更新滑块位置
            const sliderPos = ((aAnnualPct - 50) / 5) * 100;
            document.getElementById('percentSlider').style.left = `${sliderPos}%`;
            
            // 同步正向的总提成
            if (totalReverse !== totalForward) {
                totalForward = totalReverse;
                document.getElementById('totalAmount').value = totalReverse;
                calculateForward();
            }
        }
        
        // 页面加载完成后初始化
        window.onload = function() {
            // 初始化 Tailwind
            initTailwind().theme();
            
            // 初始计算
            calculateForward();
            calculateReverse();
            
            // 键盘支持
            console.log('%c✅ A 和 B 年度提成占比计算器 已就绪！', 'color:#4f46e5; font-family:monospace; font-size:13px');
        };
    </script>
</body>
</html>
